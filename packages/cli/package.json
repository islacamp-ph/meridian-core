{
  "name": "meridian-core",
  "version": "0.2.0",
  "description": "MERIDIAN command-line interface — pre-execution intelligence from your terminal",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "meridian": "dist/index.js",
    "meridian-core": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@stellar/stellar-sdk": "^13.1.0",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@meridian/ai": "*",
    "@meridian/core": "*",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
