{
  "name": "@meridian/stellar",
  "version": "0.1.0",
  "description": "JavaScript SDK for MERIDIAN — pre-execution intelligence for Stellar",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
