    "@meridian/core": "0.1.1"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "stellar",
    "soroban",
    "meridian",
    "smart-contracts"
  ],
  "license": "MIT"
