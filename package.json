{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "description": "Pre-execution intelligence for Stellar developers",
  "workspaces": [
    "packages/core",
    "packages/ai",
    "packages/api",
    "packages/cli",
    "packages/sdk-js",
    "apps/docs"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "validate:examples": "node scripts/validate-examples.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
